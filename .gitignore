# --- DEPENDENCIAS ---
# Ignora las librerías de Node en cualquier carpeta (client y server)
node_modules/
jspm_packages/

# --- CONFIGURACIÓN Y SECRETOS ---
# Ignora los archivos de variables de entorno (¡Muy importante!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- ARCHIVOS DE COMPILACIÓN ---
# Ignora las carpetas que se generan al hacer "build" para producción
dist/
build/
out/

# --- ARCHIVOS DEL SISTEMA ---
# Archivos basura que crea Windows y Mac automáticamente
.DS_Store
Thumbs.db

# --- CONFIGURACIÓN DEL EDITOR ---
# Ignora configuraciones personales de VS Code o IntelliJ
.vscode/
.idea/
*.suo
*.ntvs*

# --- LOGS Y DEBUG ---
# Archivos de error que genera npm o yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# --- EXTRAS DEL PROYECTO (Opcional) ---
# Si no quieres compartir tus copias de seguridad de SQL o notas personales
.sql
chuleta.txt